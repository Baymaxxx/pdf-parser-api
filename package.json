{
  "name": "crispi-invoice-parser",
  "version": "1.0.0",
  "description": "CRISPI Invoice Parser - Full Stack Application",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:frontend": "cd frontend && pnpm run dev",
    "dev:backend": "cd backend && python3 app.py",
    "build": "echo 'Use backend/Dockerfile for deployment'",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "pnpm run install:frontend && pnpm run install:backend",
    "install:frontend": "cd frontend && pnpm install",
    "install:backend": "cd backend && pip3 install -r requirements.txt",
    "start": "pnpm run dev",
    "test:backend": "cd backend && python3 test_api.py",
    "clean": "rm -rf frontend/node_modules frontend/pnpm-lock.yaml frontend/dist backend/__pycache__"
  },
  "keywords": [
    "pdf",
    "invoice",
    "parser",
    "ocr",
    "react",
    "flask"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
