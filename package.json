{
  "name": "crispi-invoice-parser",
  "version": "1.0.0",
  "description": "CRISPI Invoice Parser - Full Stack Application",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && python app.py",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm run install:frontend && npm run install:backend",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && pip install -r requirements.txt",
    "start": "npm run dev",
    "test:backend": "cd backend && python test_api.py",
    "clean": "rm -rf frontend/node_modules frontend/dist backend/__pycache__"
  },
  "keywords": [
    "pdf",
    "invoice",
    "parser",
    "ocr",
    "react",
    "flask"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
